# ============================================
# DeepTutor 环境变量模板（中文）
# ============================================
# 复制为 `.env` 后填写。
# 当前建议按以下分组配置：
# ports / llm / embedding / search / docker-cloud / security

# --------------------------------------------
# 端口
# --------------------------------------------
BACKEND_PORT=8001
FRONTEND_PORT=3782

# --------------------------------------------
# LLM（必填）
# --------------------------------------------
# 支持的 binding: openai, lm_studio, ollama, azure_openai, deepseek, ...
# 完整列表请运行: deeptutor provider list
LLM_BINDING=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=sk-xxx
LLM_HOST=https://api.openai.com/v1
LLM_API_VERSION=
# 可选：控制推理/思考强度。
# - DeepSeek："high" / "max" 开启思考；"minimal" 关闭
# - OpenAI o系列："low" / "medium" / "high"
# 留空则根据模型自动检测。
LLM_REASONING_EFFORT=

# --------------------------------------------
# Embedding（知识库能力必填）
# --------------------------------------------
# 支持的 binding: openai, azure_openai, cohere, jina, ollama, vllm,
# siliconflow, aliyun, custom.
#
# 重要（v1.3.0+）：EMBEDDING_HOST 必须填写“完整 endpoint URL”，
# 不是基础 URL。上面的 LLM_HOST 仍然是聊天接口 base URL；这里填写的
# embedding 地址会被原样调用，不会自动追加路径。例如：
#   OpenAI:       https://api.openai.com/v1/embeddings
#   Gemini:       https://generativelanguage.googleapis.com/v1beta/openai/embeddings
#   Cohere v4:    https://api.cohere.com/v2/embed
#   Jina:         https://api.jina.ai/v1/embeddings
#   Ollama:       http://localhost:11434/api/embed
#   SiliconFlow:  https://api.siliconflow.cn/v1/embeddings
#   Aliyun:       https://dashscope.aliyuncs.com/api/v1/services/embeddings/multimodal-embedding/multimodal-embedding
EMBEDDING_BINDING=openai
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_API_KEY=sk-xxx
EMBEDDING_HOST=https://api.openai.com/v1/embeddings
# 建议留空，让 DeepTutor 在首次 “Test connection” 成功后自动识别维度。
# 只有在需要强制指定 Matryoshka 维度时才手动填写，例如 Qwen3-Embedding
# 的 1024/1536/2048/2560/4096，或 OpenAI text-embedding-3-large 的 3072。
EMBEDDING_DIMENSION=
EMBEDDING_API_VERSION=
# 是否在请求体中携带 `dimensions` 参数：
#   true   -> 总是发送（OpenAI text-embedding-3*, Qwen3-Embedding, Qwen3-VL-Embedding）
#   false  -> 永不发送（如果提供商在收到 dimensions 参数时返回 HTTP 400，请设为 false）
#   留空或不设置 -> 自动：根据模型家族判断
EMBEDDING_SEND_DIMENSIONS=

# 各 embedding 提供商的 API Key 兜底值。当当前 embedding profile 没有
# 单独配置 api_key 时会使用这些值；设置页首次打开时也会读取它们，避免重复输入。
SILICONFLOW_API_KEY=
DASHSCOPE_API_KEY=
COHERE_API_KEY=
JINA_API_KEY=
GEMINI_API_KEY=

# ⚠️  Docker + 本地模型（LM Studio / Ollama / vLLM）
# ─────────────────────────────────────────────────────
# 当 DeepTutor 以 Docker 方式运行、而 LLM 运行在宿主机上时：
#   - 不要使用 "localhost" 或 "127.0.0.1"——容器内这些地址指向容器自身，
#     而不是宿主机。
#   - macOS / Windows (Docker Desktop): 使用 http://host.docker.internal:<端口>/v1
#   - Linux: 使用宿主机的局域网 IP，例如 http://192.168.1.100:<端口>/v1
#     （或使用 --network=host 模式启动 Docker）
#
# 示例（LM Studio 运行在 1234 端口）:
#   LLM_BINDING=lm_studio
#   LLM_HOST=http://host.docker.internal:1234/v1
#   EMBEDDING_BINDING=lm_studio
#   EMBEDDING_HOST=http://host.docker.internal:1234/v1/embeddings

# --------------------------------------------
# 搜索（可选）
# --------------------------------------------
SEARCH_PROVIDER=
SEARCH_API_KEY=
SEARCH_BASE_URL=

# --------------------------------------------
# Docker / 云部署（可选）
# --------------------------------------------
# 前端在远程部署时访问后端的公网地址
NEXT_PUBLIC_API_BASE_EXTERNAL=
# 备用 API 基础地址
NEXT_PUBLIC_API_BASE=

# --------------------------------------------
# 安全 / 网络（可选）
# --------------------------------------------
# 生产环境请保持 false
DISABLE_SSL_VERIFY=false

# --------------------------------------------
# 聊天附件（可选）
# --------------------------------------------
# 聊天运行时会把用户上传的 PDF、DOCX、图片等文件持久化到这里，
# 方便预览抽屉在内存中的 base64 被释放后仍能重新读取原文件。
#
# 默认路径为 <project>/data/user/workspace/chat/attachments；docker-compose.yml
# 已经把对应目录挂载为持久化 volume。普通 Docker / Linux 部署请留空。
# 只有在多后端实例共用共享存储（例如 NFS）时才需要覆盖。
CHAT_ATTACHMENT_DIR=
